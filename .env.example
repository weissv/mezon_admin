# ==========================================
# Mezon Admin - Root Environment Configuration
# ==========================================

# Database Connection (PostgreSQL 17 with pgvector)
DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/erp_db?schema=public"

# Backend Server Configuration
PORT=4000
NODE_ENV=development
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Frontend Origin for CORS
FRONTEND_URL="http://localhost:5173"

# Public URL for secure exam links
PUBLIC_EXAM_BASE_URL="http://localhost:5173/exam"

# AI Integration Keys (Google Gemini & Groq)
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Optional: Google Drive Integration (Knowledge Base RAG)
GOOGLE_DRIVE_API_KEY=""
GOOGLE_DRIVE_FOLDER_ID=""

# Optional: Telegram Bot Token
TELEGRAM_BOT_TOKEN=""
