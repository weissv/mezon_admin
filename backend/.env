# URL для подключения к базе данных PostgreSQL
# Use docker-compose Postgres service when running in containers
DATABASE_URL=postgresql://erp_user:erp_password_123@postgres:5432/erp_db?schema=public

# Порт, на котором будет работать API
PORT=4000

# Секретный ключ для подписи JWT токенов
JWT_SECRET="dev_secret_change_me"

# Режим запуска приложения
NODE_ENV="development"
ONEC_BASE_URL="http://100.66.251.128/mezon_db/odata/standard.odata"

# Логин 1C для Basic Auth
ONEC_USER="Главный бухгалтер"

# Пароль 1C для Basic Auth
ONEC_PASSWORD="6653"